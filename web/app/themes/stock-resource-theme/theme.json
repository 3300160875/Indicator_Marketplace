{
  "$schema": "https://schemas.wp.org/wp/6.8/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1180px"
    },
    "color": {
      "palette": [
        {
          "slug": "ink",
          "name": "Ink",
          "color": "#18202A"
        },
        {
          "slug": "paper",
          "name": "Paper",
          "color": "#FFFFFF"
        },
        {
          "slug": "market-green",
          "name": "Market Green",
          "color": "#1B7F5A"
        },
        {
          "slug": "signal-blue",
          "name": "Signal Blue",
          "color": "#2764D8"
        },
        {
          "slug": "line",
          "name": "Line",
          "color": "#D7DDE6"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "slug": "sm",
          "name": "Small",
          "size": "0.75rem"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "1.25rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "2rem"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system",
          "name": "System",
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#18202A"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "lineHeight": "1.6"
    }
  }
}
