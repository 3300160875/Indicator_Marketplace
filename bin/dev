#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

need() {
  command -v "$1" >/dev/null 2>&1 || {
    printf 'Missing required command: %s\n' "$1" >&2
    return 1
  }
}

php_lint_tracked() {
  if ! need php; then
    return 1
  fi

  git ls-files '*.php' | while IFS= read -r file; do
    php -l "$file" >/dev/null || exit 1
  done
}

package_for_module() {
  module="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"
  case "$module" in
    ""|"all"|"plugins")
      printf '%s\n' "all"
      ;;
    "contracts"|"sr-contracts")
      printf '%s\n' "packages/sr-contracts"
      ;;
    "bootstrap"|"platform"|"sr-platform-bootstrap")
      printf '%s\n' "packages/sr-platform-bootstrap"
      ;;
    "core"|"api"|"seo"|"content"|"fixtures"|"resources"|"taxonomy"|"versions"|"observability"|"sr-core")
      printf '%s\n' "packages/sr-core"
      ;;
    "sr-entitlements"|"entitlements"|"account"|"accounts"|"plans"|"rights"|"favorites")
      printf '%s\n' "packages/sr-entitlements"
      ;;
    "sr-private-downloads"|"downloads"|"storage")
      printf '%s\n' "packages/sr-private-downloads"
      ;;
    "sr-payment-gateways"|"payment"|"payments"|"checkout"|"commerce"|"orders"|"edd")
      printf '%s\n' "packages/sr-payment-gateways"
      ;;
    "sr-admin-ops"|"admin"|"audit"|"reports"|"support"|"notification")
      printf '%s\n' "packages/sr-admin-ops"
      ;;
    *)
      printf 'Unknown MODULE: %s\n' "$module" >&2
      printf 'Known examples: sr-entitlements, sr-private-downloads, sr-payment-gateways, sr-admin-ops, sr-core, contracts, bootstrap, account, downloads.\n' >&2
      return 2
      ;;
  esac
}

run_package_test() {
  package_dir="$1"
  if [ ! -f "$package_dir/composer.json" ]; then
    printf 'Missing package composer.json: %s\n' "$package_dir" >&2
    return 1
  fi

  if command -v composer >/dev/null 2>&1; then
    composer --working-dir="$package_dir" test
    return $?
  fi

  if [ -f "$package_dir/tests/run.php" ]; then
    php "$package_dir/tests/run.php"
    return $?
  fi

  printf 'No package test runner found: %s\n' "$package_dir" >&2
  return 1
}

run_all_package_tests() {
  for package_dir in packages/*; do
    if [ -f "$package_dir/composer.json" ]; then
      run_package_test "$package_dir"
    fi
  done
}

case "${1:-help}" in
  help)
    cat <<'EOF'
Development commands:
  make bootstrap   first local start: copy .env, install Composer deps, start Docker services
  make up          start local Docker services
  make down        stop local Docker services
  make reset       remove local Docker services and disposable volumes
  make install     run Composer install in the Docker CLI container
  make migrate     run database migrations when available
  make seed        run seed data when available
  make lint        validate compose, shell scripts, Composer metadata and tracked PHP syntax
  make test        run local smoke-level tests available in W1
  make test-unit MODULE=<name>
                   run package-level unit tests for a module alias
  make test-integration TEST=<name>
                   run repository integration gate; TEST narrows the intent label when available
  make test-concurrency TEST=<name>
                   run deterministic concurrency checks when a TEST alias is available
  make test-smoke  verify running Docker services
  make e2e         run end-to-end tests when available
  make status      show Docker service status
  make ci          run the minimum local CI gate
  make doctor      check local command prerequisites

First start:
  make doctor
  make bootstrap
  make test-smoke
EOF
    ;;
  doctor)
    need docker
    docker compose version >/dev/null
    need git
    if command -v composer >/dev/null 2>&1; then
      composer --version >/dev/null
    fi
    printf 'doctor: ok\n'
    ;;
  bootstrap)
    exec infra/docker/bootstrap.sh
    ;;
  up)
    docker compose up -d mariadb redis minio mailpit php nginx minio-init
    ;;
  down)
    docker compose down
    ;;
  reset)
    docker compose down -v
    ;;
  install)
    docker compose run --rm cli composer install --no-interaction --prefer-dist
    ;;
  migrate)
    printf 'migrate: no database migrations are defined in W1\n'
    ;;
  seed)
    printf 'seed: no seed data is defined in W1\n'
    ;;
  lint)
    docker compose config --quiet
    sh -n bin/dev
    sh -n infra/docker/bootstrap.sh
    sh -n infra/docker/smoke.sh
    if command -v composer >/dev/null 2>&1; then
      composer validate --strict --no-check-publish >/dev/null
    fi
    php_lint_tracked
    printf 'lint: ok\n'
    ;;
  test)
    bin/dev lint
    printf 'test: ok\n'
    ;;
  test-unit)
    target="$(package_for_module "${2:-all}")"
    if [ "$target" = "all" ]; then
      run_all_package_tests
    else
      run_package_test "$target"
    fi
    printf 'test-unit: ok\n'
    ;;
  test-integration)
    label="${2:-all}"
    if [ -n "$label" ]; then
      printf 'test-integration: running repository gate for %s\n' "$label"
    fi
    bin/dev test
    printf 'test-integration: ok\n'
    ;;
  test-concurrency)
    label="$(printf '%s' "${2:-all}" | tr '[:upper:]' '[:lower:]')"
    case "$label" in
      "downloadtokens"|"downloads"|"storage")
        if [ "$label" = "downloadtokens" ] && [ -f "docs/evidence/SR-053/download-token-check.php" ]; then
          php docs/evidence/SR-053/download-token-check.php
        fi
        run_package_test "packages/sr-private-downloads"
        ;;
      "entitlements")
        run_package_test "packages/sr-entitlements"
        ;;
      "payment")
        run_package_test "packages/sr-payment-gateways"
        ;;
      ""|"all")
        run_all_package_tests
        ;;
      *)
        printf 'test-concurrency: no dedicated suite for %s; running repository gate\n' "$label"
        bin/dev test
        ;;
    esac
    printf 'test-concurrency: ok\n'
    ;;
  smoke|test-smoke)
    exec infra/docker/smoke.sh
    ;;
  e2e)
    printf 'e2e: no end-to-end suite is defined in W1\n'
    ;;
  status)
    docker compose ps
    ;;
  ci)
    composer validate --strict
    npm ci
    bin/dev lint
    bin/dev test
    npm run lint
    printf 'ci: ok\n'
    ;;
  *)
    printf 'Unknown command: %s\n' "$1" >&2
    printf 'Run `make help` for available commands.\n' >&2
    exit 2
    ;;
esac
