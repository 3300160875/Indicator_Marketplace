COMPOSE_PROJECT_NAME='indicator-marketplace'

APP_PORT='18080'

DB_NAME='indicator_marketplace'
DB_USER='indicator'
DB_PASSWORD='indicator-local-only'
DB_ROOT_PASSWORD='root-local-only'

# Optionally, you can use a data source name (DSN)
# When using a DSN, you can remove the DB_NAME, DB_USER, DB_PASSWORD, and DB_HOST variables
# DATABASE_URL='mysql://database_user:database_password@database_host:database_port/database_name'

# Optional database variables
DB_HOST='mariadb'
# DB_HOST='127.0.0.1' # Use if you encounter mysqli 2002 / socket connection issues
DB_PORT='3307'
DB_PREFIX='wp_'

WP_ENV='development'
WP_HOME='http://localhost:18080'
WP_SITEURL="${WP_HOME}/wp"

REDIS_HOST='redis'
REDIS_PORT='6379'
REDIS_HOST_PORT='6380'

MINIO_ROOT_USER='minioadmin-local'
MINIO_ROOT_PASSWORD='minioadmin-local'
MINIO_API_PORT='9002'
MINIO_CONSOLE_PORT='9003'
S3_ENDPOINT='http://minio:9000'
S3_BUCKET='indicator-assets'
S3_REGION='us-east-1'
S3_USE_PATH_STYLE_ENDPOINT='true'

MAIL_HOST='mailpit'
MAIL_PORT='1025'
MAILPIT_HTTP_PORT='8025'
MAILPIT_SMTP_PORT='1025'

# Specify optional debug.log path
# WP_DEBUG_LOG='/path/to/debug.log'

# Development-only placeholders. Replace in real environments.
AUTH_KEY='changeme-local-only'
SECURE_AUTH_KEY='changeme-local-only'
LOGGED_IN_KEY='changeme-local-only'
NONCE_KEY='changeme-local-only'
AUTH_SALT='changeme-local-only'
SECURE_AUTH_SALT='changeme-local-only'
LOGGED_IN_SALT='changeme-local-only'
NONCE_SALT='changeme-local-only'
